# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Environment / secrets  (keep *.example templates)
# =============================================================================
.env
.env.*
!.env.example
!.env*.example

# =============================================================================
# Build output
# =============================================================================
# Next.js (apps/web, apps/platform)
.next/
out/
next-env.d.ts

# NestJS / TypeScript (apps/api, packages/*)
dist/
build/
*.tsbuildinfo

# Turborepo
.turbo/

# =============================================================================
# Prisma
# =============================================================================
# The generated client lives in node_modules (already ignored). Keep the schema
# and any migrations tracked.
packages/database/generated/

# =============================================================================
# Logs & debug
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# Testing / coverage
# =============================================================================
coverage/
.nyc_output/

# =============================================================================
# Mobile — Expo / React Native (apps/mobile)
# =============================================================================
.expo/
.expo-shared/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# iOS
apps/mobile/ios/build/
apps/mobile/ios/Pods/
apps/mobile/ios/*.xcworkspace/xcuserdata/

# Android
apps/mobile/android/build/
apps/mobile/android/app/build/
apps/mobile/android/.gradle/
apps/mobile/android/local.properties
*.keystore
!debug.keystore

# =============================================================================
# Uploads served from local disk (runtime user content, not source)
# =============================================================================
apps/api/uploads/

# =============================================================================
# OS / editor / tooling
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
*.swp
*.swo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# =============================================================================
# Docker (local overrides)
# =============================================================================
docker-compose.override.yml
