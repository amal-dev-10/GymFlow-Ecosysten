# =============================================================================
# Copy to `.env` (docker compose reads it automatically):  cp .env.docker.example .env
# =============================================================================

# ---- Database ----------------------------------------------------------------
POSTGRES_USER=gymflow
POSTGRES_PASSWORD=change_me
POSTGRES_DB=gymflow

# ---- API ---------------------------------------------------------------------
# Use a long random string in production.
JWT_SECRET=please_change_this_in_production

# Browser origins allowed to call the API (comma-separated). Match your real
# scheme+domains. In production use https://
CORS_ORIGINS=http://gymflow.io,http://admin.gymflow.io

# Payments (optional — leave blank to disable Razorpay).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Frontends (build-time, baked into the bundles) --------------------------
# Public origin of the API as reached from the BROWSER.
# Local (with the hosts-file trick below): http://api.gymflow.io
# Production:                                https://api.gymflow.io
NEXT_PUBLIC_API_URL=http://api.gymflow.io

# Public Razorpay key for the tenant client (optional).
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# =============================================================================
# Local testing without real DNS — add to /etc/hosts:
#   127.0.0.1  gymflow.io www.gymflow.io admin.gymflow.io api.gymflow.io
# then open http://gymflow.io and http://admin.gymflow.io
# =============================================================================
